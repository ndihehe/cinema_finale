<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="http://xmlns.jcp.org/xml/ns/persistence" version="2.1">
    <persistence-unit name="CinemaPU" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>org.example.cinema_finale.entity.Phim</class>
        <class>org.example.cinema_finale.entity.SuatChieu</class>
        <class>org.example.cinema_finale.entity.KhachHang</class>
        <class>org.example.cinema_finale.entity.NhanVien</class>
        <class>org.example.cinema_finale.entity.TaiKhoan</class>
        <class>org.example.cinema_finale.entity.LoaiVe</class>
        <class>org.example.cinema_finale.entity.Ve</class>
        <class>org.example.cinema_finale.entity.DonHang</class>
        <class>org.example.cinema_finale.entity.ChiTietDonHangVe</class>
        <class>org.example.cinema_finale.entity.ThanhToan</class>

        <properties>
            <property name="javax.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
            <property name="jakarta.persistence.jdbc.url"
                      value="jdbc:mysql://localhost:3306/quanlybanvexemphim?useSSL=false&amp;allowPublicKeyRetrieval=true&amp;serverTimezone=UTC"/>
            <property name="javax.persistence.jdbc.user" value="root"/>
            <property name="javax.persistence.jdbc.password" value="1234567890"/>

            <property name="hibernate.dialect"
                      value="org.hibernate.dialect.MySQLDialect"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
        </properties>
    </persistence-unit>
</persistence>